<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FindIt" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/findit_launch_background</item>
        <item name="android:colorAccent">@color/findit_launch_background</item>
    </style>

    <style name="Theme.FindIt.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/findit_launch_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.FindIt</item>
    </style>
</resources>
